# ============================================================
# FUND-OS 支付生产环境配置模板（复制为 .env 后填充真实值）
# ============================================================

# 模式：sandbox（演示/本地） | production（真实收款）
PAYMENT_MODE=production

# ---- 支付宝（开放平台：https://open.alipay.com） ----
ALIPAY_APP_ID=你的应用APPID
# 应用私钥（PEM，含 -----BEGIN RSA PRIVATE KEY-----）
# 推荐用文件加载：把私钥存到文件并设置 ALIPAY_PRIVATE_KEY_PATH
ALIPAY_PRIVATE_KEY_PATH=/run/secrets/alipay_private.pem
ALIPAY_PRIVATE_KEY=
# 支付宝公钥（平台「开发设置 → 加签方式 → 支付宝公钥」复制，不是应用公钥）
ALIPAY_PUBLIC_KEY_PATH=/run/secrets/alipay_public.pem
ALIPAY_PUBLIC_KEY=

# ---- 微信支付（商户平台：https://pay.weixin.qq.com，API v2） ----
WECHAT_APP_ID=你的微信APPID
WECHAT_MCH_ID=你的商户号
# API v2 密钥（32 字节，商户平台「API 安全 → API 密钥」设置）
WECHAT_API_KEY_PATH=/run/secrets/wechat_api_key.txt
WECHAT_API_KEY=

# ---- 公网回跳地址（生产必须为 https 公网可访问域名） ----
PAYMENT_NOTIFY_BASE=https://your-domain.com
# 支付宝同步回跳页：必须是 /api/billing/return（即验签路由，见 billing_bp.api_billing_return）
PAYMENT_RETURN_URL=https://your-domain.com/api/billing/return

# ---- 数据行情（非支付相关，按需配置） ----
TUSHARE_TOKEN=

# ---- 站点与合规（P2：页脚/关于页展示，生产务必填真实值） ----
SITE_NAME=FUND-OS 智能基金估算系统
COMPANY_NAME=你的运营主体公司全称
ICP_BEIAN=京ICP备00000000号-1
POLICE_BEIAN=京公网安备00000000000000号
CONTACT_EMAIL=support@your-domain.com
SERVICE_TEL=400-000-0000
